generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id              String   @id @default(cuid())
  ean             String?
  ref             String?
  nombre          String
  marca           String
  precioOriginal  Float    // Costo B2B
  margen          Float    @default(0.10) // 10% por defecto
  precioVenta     Float    // Computado como originalCost * (1 + margin)
  pvpr            String?  // PVPR del proveedor
  agotado         Boolean  @default(false)
  imagen          String?
  urlOriginal     String?
  descripcion     String?
  ingredientes    String?
  formato         String?  // Ej: 400ml, 1kg, 200g

  precioCompetencia Float?
  competenciaUrl    String?
  competenciaNombre String?
  oculto            Boolean  @default(false)
  enPromocion       Boolean  @default(false)
  needsReview       Boolean  @default(false)

  videoUrl          String?
  captions          Json?
  isNuevo         Boolean  @default(false)
  isAiGenerated   Boolean  @default(false)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  orderItems      OrderItem[]
}

model Order {
  id            String      @id @default(cuid())
  customerName  String
  customerEmail String
  customerPhone String?
  address       String?
  totalAmount   Float
  status        String      @default("PENDING") // PENDING, COMPLETED, CANCELLED
  revolutOrderId String?
  trackingNumber String?
  items         OrderItem[]
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float    // PVP frozen at purchase time
}

model Recipe {
  id            String   @id @default(cuid())
  nombre        String
  slug          String   @unique
  descripcion   String?
  imagen        String?
  prepTime      Int?     // minutos
  cookTime      Int?     // minutos
  dificultad    String?  // Facil, Media, Alta
  instrucciones String   @db.Text // Pasos detallados
  ingredientes  String   @db.Text // JSON string: [{name, amount, productId?}]
  publicado     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
